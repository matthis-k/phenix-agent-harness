{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@matthis-k/phenix-kernel/*": ["packages/phenix-kernel/*"],
      "@matthis-k/phenix-flow/*": ["packages/phenix-flow/*"],
      "@matthis-k/phenix-routing/*": ["packages/phenix-routing/*"],
      "@matthis-k/phenix-contracts/*": ["packages/phenix-contracts/*"],
      "@hypabolic/pi-hypa/extensions/index.ts": ["extensions/optional-integrations.d.ts"],
      "@hypabolic/pi-hypa/extensions/rewrite-client.ts": ["extensions/optional-integrations.d.ts"],
      "@hypabolic/pi-hypa/extensions/tools.ts": ["extensions/optional-integrations.d.ts"],
      "pi-lsp/extensions/pi-lsp/index.ts": ["extensions/optional-integrations.d.ts"],
      "pi-mcp-adapter/index.ts": ["extensions/optional-integrations.d.ts"],
      "pi-context-tools/extensions/index.ts": ["extensions/optional-integrations.d.ts"],
      "@juicesharp/rpiv-web-tools/index.ts": ["extensions/optional-integrations.d.ts"]
    }
  },
  "include": ["extensions/**/*.ts", "packages/**/*.ts"],
  "exclude": ["node_modules"]
}
