{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "types": ["node"]
  },
  "include": [
    "adapters/**/*.ts",
    "application/**/*.ts",
    "composition/**/*.ts",
    "definitions/**/*.ts",
    "domain/**/*.ts",
    "extension/**/*.ts",
    "ports/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
