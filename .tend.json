{
  "version": 2,
  "profiles": {
    "git-hook": {
      "phase": "verify",
      "selection": "staged",
      "tasks": ["changed-files", "repository-checks"],
      "contexts": ["local"]
    },
    "manual": {
      "phase": "verify",
      "selection": "changed",
      "tasks": ["changed-files", "repository-checks", "runtime-tests", "typecheck"],
      "contexts": ["local"]
    },
    "full": {
      "phase": "verify",
      "selection": "full",
      "tasks": ["repository-checks", "runtime-tests", "typecheck"],
      "contexts": ["local", "nix-sandbox"]
    },
    "pre-push": {
      "phase": "verify",
      "selection": "full",
      "tasks": ["flake-check"],
      "contexts": ["local"]
    },
    "ci": {
      "phase": "verify",
      "selection": "git-range",
      "tasks": ["changed-files", "repository-checks", "runtime-tests", "typecheck", "flake-check"],
      "contexts": ["ci"]
    },
    "fix": {
      "phase": "fix",
      "selection": "staged",
      "tasks": ["format-files"],
      "contexts": ["local"]
    }
  },
  "contexts": {
    "local": {
      "implementation": "nix",
      "allow_mutation": true,
      "allow_interactive": false,
      "allow_network": true,
      "require_sandbox_safe": false
    },
    "ci": {
      "implementation": "nix",
      "allow_mutation": false,
      "allow_interactive": false,
      "allow_network": true,
      "require_sandbox_safe": false
    },
    "nix-sandbox": {
      "implementation": "direct",
      "allow_mutation": false,
      "allow_interactive": false,
      "allow_network": false,
      "require_sandbox_safe": true
    }
  },
  "node": {
    "id": "phenix-agent-harness",
    "description": "Verify and maintain the Phenix Pi harness",
    "tasks": [
      {
        "id": "changed-files",
        "description": "Check selected repository files",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": [".github/**", ".tend.json", "*.json", "*.jsonc", "*.nix", "modules/**"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["phenix-check-files"],
            "file_args": "matched",
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "repository-checks",
        "description": "Run repository-wide workflow and configuration checks",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": [".github/**", ".tend.json", "biome.json", "*.nix", "modules/**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["phenix-check-repository"],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "runtime-tests",
        "description": "Run the packaged TypeScript runtime tests",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["modules/phenix-pi/**", "modules/pi-npm/**", "modules/pi-packages.nix"]
          }
        },
        "implementations": {
          "nix": {
            "kind": "command",
            "command": [
              "nix",
              "build",
              "--no-link",
              "--print-build-logs",
              ".#phenix-runtime-tests"
            ],
            "network": true
          },
          "direct": {
            "kind": "command",
            "command": ["phenix-check-runtime", "runtime-tests"],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "typecheck",
        "description": "Run the authoritative TypeScript compiler check",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["modules/phenix-pi/**", "modules/pi-npm/**", "modules/pi-packages.nix"]
          }
        },
        "implementations": {
          "nix": {
            "kind": "command",
            "command": ["nix", "build", "--no-link", "--print-build-logs", ".#phenix-typecheck"],
            "network": true
          },
          "direct": {
            "kind": "command",
            "command": ["phenix-check-runtime", "typecheck"],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "flake-check",
        "description": "Run the complete reproducible flake gate",
        "phase": "verify",
        "always": true,
        "implementations": {
          "nix": {
            "kind": "command",
            "command": ["nix", "flake", "check", "--print-build-logs", "--keep-going"],
            "network": true
          }
        }
      },
      {
        "id": "format-files",
        "description": "Apply supported formatters to selected staged files",
        "phase": "fix",
        "when": {
          "changed": {
            "paths": [".tend.json", "*.json", "*.jsonc", "*.nix", "modules/**"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["phenix-format-files"],
            "file_args": "matched",
            "mutates": true
          }
        }
      }
    ]
  }
}
